# Node modules (will be installed in container)
node_modules

# Cache directory (will be created in container)
.cache

# Internal JSON backups (created during Docker build for backward compatibility)
*-internal.json

# Custom JSON configuration directories
json/

# Logs directory
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test files
test-thumbnail.png
helpers/test.js
test/output/*
!test/output/.gitkeep

# Snapshot regression PNGs (local artifacts; only manifest.json is committed)
test/snapshots/baseline/
test/snapshots/current/
test/snapshots/snapshot-results.json

# Lock files from other package managers (this project uses yarn)
package-lock.json
pnpm-lock.yaml

# Environment files
.env

# IDE files
.claude
.agents/
.codex/
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
.github/copilot-instructions.md
CHANGELOG.md
HIGHLIGHTS.md

# Beads / Dolt files (added by bd init)
# Only the .jsonl exports belong in the repo; everything else under .beads/ is local.
.beads/*
!.beads/*.jsonl
.dolt/
*.db
.beads-credential-key
